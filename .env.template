# ───────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────
# Port on which the NestJS HTTP server listens (default: 3000)
API_PORT=

# ───────────────────────────────────────────────
# Database
# ───────────────────────────────────────────────
# MongoDB connection string (e.g. mongodb://localhost:27017/prismart)
MONGO_URI=

# ───────────────────────────────────────────────
# Authentication (JWT)
# ───────────────────────────────────────────────
# Secret key used to sign and verify JSON Web Tokens
JWT_SECRET=
# Token lifetime (e.g. 24h, 7d, 3600)
JWT_EXPIRES_IN=

# ───────────────────────────────────────────────
# Super Admin Bootstrap (optional)
# ───────────────────────────────────────────────
# If all three values are provided, a SUPER_ADMIN user is created
# automatically on application startup. Omit them to skip this step.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_USERNAME=

# ───────────────────────────────────────────────
# Cloudinary (image uploads)
# ───────────────────────────────────────────────
# Credentials for the Cloudinary media service used to upload
# product and review images.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ───────────────────────────────────────────────
# CORS
# ───────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. http://localhost:3000,https://myapp.com)
CORS_ORIGIN=